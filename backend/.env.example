# --- Server ---
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-in-production-please-make-this-long-and-random
CORS_ORIGIN=http://localhost:5173

# --- LLM provider ---
# Choose one of: openai | groq | anthropic | openai_compatible
LLM_PROVIDER=groq

# API key for whichever provider you pick
LLM_API_KEY=
# Model name, e.g. gpt-4o-mini, llama-3.1-70b-versatile, claude-3-5-sonnet-latest
LLM_MODEL=llama-3.1-70b-versatile
# Custom base URL (only for openai_compatible, leave blank otherwise)
LLM_BASE_URL=

# --- Storage ---
DATA_DIR=./data
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20
